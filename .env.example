# ------------
# Core network
# ------------
TZ=UTC
JANUS_RTP_MIN_PORT=10000
JANUS_RTP_MAX_PORT=20000
JANUS_RTP_PORT_RANGE=10000-20000

# ----------------
# Janus logging
# ----------------
JANUS_DEBUG_LEVEL=4
JANUS_DEBUG_TIMESTAMPS=true
JANUS_DEBUG_COLORS=false
JANUS_EXTRA_ARGS=

# ----------------
# Janus NAT/ICE
# ----------------
JANUS_STUN_SERVER=stun.l.google.com
JANUS_STUN_PORT=19302
JANUS_NAT_1_1_MAPPING=
JANUS_NICE_DEBUG=false
JANUS_FULL_TRICKLE=true
JANUS_IPV6=false
JANUS_DTLS_MTU=1200

# ----------------
# Janus HTTP API
# ----------------
JANUS_HTTP_ENABLED=true
JANUS_HTTP_PORT=8088
JANUS_HTTPS_ENABLED=false
JANUS_HTTPS_PORT=8089
JANUS_HTTP_BASE_PATH=/janus

JANUS_ADMIN_HTTP_ENABLED=false
JANUS_ADMIN_HTTP_PORT=7088
JANUS_ADMIN_HTTPS_ENABLED=false
JANUS_ADMIN_HTTPS_PORT=7889
JANUS_ADMIN_BASE_PATH=/admin

# -----------------------
# Janus WebSockets API
# -----------------------
JANUS_WS_ENABLED=true
JANUS_WS_PORT=8188
JANUS_WSS_ENABLED=false
JANUS_WSS_PORT=8989
JANUS_WS_EVENTS=false

JANUS_ADMIN_WS_ENABLED=false
JANUS_ADMIN_WS_PORT=7188
JANUS_ADMIN_WSS_ENABLED=false
JANUS_ADMIN_WSS_PORT=7989

# ----------------
# Certificates
# ----------------
JANUS_CERT_PEM=/opt/janus/share/janus/certs/mycert.pem
JANUS_CERT_KEY=/opt/janus/share/janus/certs/mycert.key

# ----------------
# SIP bridge
# ----------------
SIP_LOCAL_IP=0.0.0.0
SIP_LOCAL_PORT=5060
SIP_BEHIND_NAT=true
SIP_USER_AGENT=Janus-WebRTC-SIP-Bridge
SIP_REGISTER_TTL=3600
SIP_KEEPALIVE_INTERVAL=120

# SIP helper account (optional)
SIP_ACCOUNT_USERNAME=
SIP_ACCOUNT_AUTHUSER=
SIP_ACCOUNT_SECRET=
SIP_PROXY=sip:your-sip-proxy.example.com:5060
SIP_REGISTRAR=sip:your-sip-registrar.example.com:5060
SIP_ACCOUNT_DISPLAY_NAME=
